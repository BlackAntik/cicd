{
  "title": "Warehouse Infrastructure",
  "uid": "warehouse-infrastructure",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Kafka Consumer Lag by Topic/Partition",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(kafka_consumergroup_lag{job=\"kafka-exporter\"}) by (consumergroup, topic)",
          "legendFormat": "{{consumergroup}} / {{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2},
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "id": 2,
      "title": "Kafka Partition Count by Topic",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "count(kafka_topic_partition_current_offset{job=\"kafka-exporter\"}) by (topic)",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 3,
      "title": "Kafka Broker Status (Online Partitions)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "kafka_brokers{job=\"kafka-exporter\"}",
          "legendFormat": "brokers online",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2},
          "color": {"mode": "fixed", "fixedColor": "green"}
        }
      }
    },
    {
      "id": 4,
      "title": "Kafka Message Produce Rate (from exporter)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(kafka_topic_partition_current_offset{job=\"kafka-exporter\"}[1m])) by (topic)",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 5,
      "title": "Cassandra Read Latency p99 (µs)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "cassandra_table_read_latency{job=\"cassandra-exporter\", quantile=\"0.99\"}",
          "legendFormat": "{{keyspace}}.{{table}} p99",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "cassandra_table_read_latency{job=\"cassandra-exporter\", quantile=\"0.95\"}",
          "legendFormat": "{{keyspace}}.{{table}} p95",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "cassandra_table_read_latency{job=\"cassandra-exporter\", quantile=\"0.50\"}",
          "legendFormat": "{{keyspace}}.{{table}} p50",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 6,
      "title": "Cassandra Write Latency p99 (µs)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "cassandra_table_write_latency{job=\"cassandra-exporter\", quantile=\"0.99\"}",
          "legendFormat": "{{keyspace}}.{{table}} p99",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "cassandra_table_write_latency{job=\"cassandra-exporter\", quantile=\"0.95\"}",
          "legendFormat": "{{keyspace}}.{{table}} p95",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "cassandra_table_write_latency{job=\"cassandra-exporter\", quantile=\"0.50\"}",
          "legendFormat": "{{keyspace}}.{{table}} p50",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 7,
      "title": "Cassandra Pending Compactions",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "cassandra_table_pending_compactions{job=\"cassandra-exporter\"}",
          "legendFormat": "{{keyspace}}.{{table}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2},
          "color": {"mode": "fixed", "fixedColor": "orange"}
        }
      }
    },
    {
      "id": 8,
      "title": "Cassandra Live Disk Space Used (bytes)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "cassandra_table_live_disk_space_used{job=\"cassandra-exporter\"}",
          "legendFormat": "{{keyspace}}.{{table}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 9,
      "title": "Kafka Consumer Lag Total",
      "type": "stat",
      "gridPos": {"x": 0, "y": 32, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(kafka_consumergroup_lag{job=\"kafka-exporter\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 1000}
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Kafka Brokers Online",
      "type": "stat",
      "gridPos": {"x": 6, "y": 32, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "kafka_brokers{job=\"kafka-exporter\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Cassandra Max Pending Compactions",
      "type": "stat",
      "gridPos": {"x": 12, "y": 32, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "max(cassandra_table_pending_compactions{job=\"cassandra-exporter\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Cassandra Total Live Disk Space",
      "type": "stat",
      "gridPos": {"x": 18, "y": 32, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(cassandra_table_live_disk_space_used{job=\"cassandra-exporter\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0}
            ]
          }
        }
      }
    }
  ]
}
